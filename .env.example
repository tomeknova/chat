APP_NAME="KINGS Docs Asystent"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Europe/Warsaw

APP_LOCALE=pl
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pl_PL

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Baza danych: połączenie 'mysql' (local=MariaDB, prod=MySQL 8.4 LTS). ---
# --- Bazę i usera tworzy agent serwerowy — patrz docs/DB_SETUP.md. ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=chat
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# =============================================================================
# AskDocs — asystent AI
# Pełny opis i wartości domyślne: config/askdocs.php. Precedencja źródeł: docs/AGENT_GUIDE.md.
# =============================================================================

# Routing providerów. default = primary; fallback (opcjonalny) użyty, gdy primary padnie lub nie ugruntuje odpowiedzi.
ASKDOCS_PROVIDER=openrouter          # openrouter | bielik
# ASKDOCS_FALLBACK=openrouter        # hybryda, np. bielik primary -> openrouter fallback
ASKDOCS_RETRIEVER=full               # full (duży kontekst — OpenRouter) | lexical (WYMAGANY dla Bielika)

# OpenRouter (klucz ustawiany raz na serwerze, NIGDY w gicie).
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL=openai/gpt-5.4-nano

# Bielik (lokalny Ollama). Lokalnie wystarczy BIELIK_BASE_URL.
# Prod cross-host: ustaw BIELIK_HOST (FQDN, nie IP) + BIELIK_ALLOWED_CIDR — endpoint rozwiązywany po NAZWIE + allowlista (anty-SSRF).
# BIELIK_BASE_URL=http://localhost:11434/v1
# BIELIK_MODEL=bielik-11b-v3-q80:latest
# BIELIK_HOST=
# BIELIK_PORT=11434
# BIELIK_ALLOWED_CIDR=192.168.10.0/24   # dozwolone sieci, oddzielone przecinkiem
# BIELIK_TIMEOUT=12

# Limity / odporność (domyślne są sensowne — zmieniaj świadomie).
# ASKDOCS_TOP_K=8
# ASKDOCS_MAX_CHARS=12000
# ASKDOCS_DEADLINE=35
# ASKDOCS_LEASE=60
# ASKDOCS_BREAKER_THRESHOLD=3

# Brama kosztów / bezpieczeństwa.
AI_ENABLED=true                      # kill-switch; false = asystent abstynuje bez wywołań AI
AI_DAILY_BUDGET_USD=1.0              # dzienny limit kosztu USD (Bielik = 0, więc budżetu nie zużywa)
OWNER_TOKEN_PEPPER=                  # losowy sekret do hashowania tokenu właściciela rozmowy (fallback: APP_KEY)

# Korpus dokumentacji.
CORPUS_SOURCE_PATH=/opt/lampp/htdocs/kings5-docs   # repo źródłowe docs (markdown) dla chat:build-corpus
DOCS_BASE_URL=https://kings5-docs.mixpost.pl       # prefiks dołączany do canonical_url przy renderze
# CORPUS_APPROVAL_KEY=assistant                    # frontmatter gate: tylko strony z `assistant: true`
